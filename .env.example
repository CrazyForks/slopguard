# ─────────────────────────────────────────────────────────────
# SlopGuard environment variables
# Copy to .env.local for local dev, set the same keys in Vercel.
# ─────────────────────────────────────────────────────────────

# --- GitHub App credentials (from the App settings page / manifest flow) ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Webhook secret you set when creating the App
GITHUB_WEBHOOK_SECRET=
# Private key (.pem). Two ways to provide it:
#  1) Paste the whole PEM here with literal \n escaped newlines, OR
#  2) base64-encode the pem and put it in GITHUB_APP_PRIVATE_KEY_BASE64
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=

# --- LLM providers (at least ONE recommended; falls back to heuristics-only) ---

# Google Gemini (recommended — generous free tier, falls back automatically)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Preference order is configurable via LLM_PROVIDER_ORDER below.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Grok (x.ai) — OpenAI-compatible endpoint
XAI_API_KEY=
XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1

# Generic OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated preference order: anthropic,grok,openai
LLM_PROVIDER_ORDER=gemini,anthropic,grok,openai

# --- App config ---
# Public base URL of this deployment (used in comment links / dashboard).
APP_BASE_URL=http://localhost:3000
# Default slop score threshold (0-100) when a repo has no SLOP_POLICY.yml
DEFAULT_SLOP_THRESHOLD=60
# Quarantine label name
DEFAULT_QUARANTINE_LABEL=slop-quarantine

# --- Operational tuning (safe defaults) ---
# Max LLM wait before degrading to heuristics-only (ms)
LLM_TIMEOUT_MS=25000
# Max analyses per repo per minute (PR-spam flood protection)
RATE_LIMIT_PER_MIN=30

# --- Billing / plans (optional — free tier works without any of these) ---
# Comma-separated GitHub logins entitled to managed LLM (Pro/Team).
PRO_OWNERS=
TEAM_OWNERS=
# Polar Checkout Link URLs (Merchant of Record; from polar.sh dashboard).
POLAR_LINK_PRO=
POLAR_LINK_TEAM=
# Automatic entitlements (no DB): resolve paid plans from active Polar
# subscriptions. Customers enter their GitHub org/username in a checkout
# custom field (key below). Optional — without these, use PRO_OWNERS/TEAM_OWNERS.
POLAR_API_TOKEN=          # Organization Access Token (read subscriptions)
POLAR_WEBHOOK_SECRET=     # Standard Webhooks secret for /api/polar/webhook
POLAR_ORG_ID=            # optional; scopes subscription lookups
POLAR_GITHUB_FIELD_KEY=github-login  # checkout custom-field slug holding the GitHub login
POLAR_SERVER=production  # or "sandbox" for test mode
